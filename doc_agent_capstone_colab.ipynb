    "\n",
    "if not validation.is_valid:\n",
    "    print(f\"Auto-correcting: {validation.failed_fields}\")\n",
    "    extraction = correct(images[0], extraction, validation)\n",
    "\n",
    "    # Re-validate after correction\n",
    "    validation = validate(extraction)\n",
    "    status_icon = \"✅\" if validation.is_valid else \"⚠️\"\n",
    "    print(f\"After correction — {status_icon} {'PASSED' if validation.is_valid else 'Routing to human review'}\")\n",
    "else:\n",
    "    print(\"✅ No corrections needed — all fields passed validation.\")"
   ]
  },

