    "---\n",
    "# 🚀 STEP 4 — Launch Doc Agent\n",
    "\n",
    "This cell starts the Streamlit web app and creates a **public URL** using Cloudflare Tunnel.\n",
    "\n",
    "- The URL is printed in a box below — **open it in your browser**\n",
    "- **Login:** `demo` / `demo`\n",
    "- The app stays live as long as this Colab session is running\n",
    "- Each session gives a new URL (this is normal)\n",
    "\n",
    "> ⏳ This cell takes about 15 seconds — wait until you see the URL box."
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import subprocess, time, re, sys, os\n",
    "\n",
    "os.chdir(\"/content/capstone\")\n",
    "\n",
    "# ── 1. Download Cloudflare tunnel binary (no account needed) ─────────────\n",
    "!wget -q -O /usr/local/bin/cloudflared \\\n",
    "    https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-amd64\n",
    "!chmod +x /usr/local/bin/cloudflared\n",
    "\n",
    "# ── 2. Start Streamlit server in the background ──────────────────────────\n",
    "streamlit_proc = subprocess.Popen(\n",
    "    [\n",
    "        sys.executable, \"-m\", \"streamlit\", \"run\", \"app.py\",\n",
    "        \"--server.port\",               \"8501\",\n",
    "        \"--server.headless\",            \"true\",\n",
    "        \"--server.enableCORS\",          \"false\",\n",
    "        \"--server.enableXsrfProtection\",\"false\",\n",
    "    ],\n",
    "    cwd=\"/content/capstone\",\n",
    "    stdout=subprocess.PIPE,\n",
    "    stderr=subprocess.PIPE,\n",
    ")\n",
    "print(\"⏳ Starting Streamlit server...\")\n",
    "time.sleep(8)\n",
    "\n",
    "# ── 3. Open Cloudflare Tunnel and grab the public URL ────────────────────\n",
    "tunnel_proc = subprocess.Popen(\n",
    "    [\"/usr/local/bin/cloudflared\", \"tunnel\", \"--url\", \"http://localhost:8501\"],\n",
    "    stdout=subprocess.PIPE,\n",
    "    stderr=subprocess.PIPE,\n",
    ")\n",
    "\n",
    "public_url = None\n",
    "print(\"⏳ Creating public tunnel (up to 30s)...\")\n",
    "for _ in range(40):\n",
    "    line = tunnel_proc.stderr.readline().decode(\"utf-8\", errors=\"ignore\")\n",
    "    match = re.search(r\"https://[a-z0-9\\-]+\\.trycloudflare\\.com\", line)\n",
    "    if match:\n",
    "        public_url = match.group()\n",
    "        break\n",
    "    time.sleep(1)\n",
    "\n",
    "# ── 4. Print result ──────────────────────────────────────────────────────\n",
    "if public_url:\n",
    "    pad = \" \" * max(0, 52 - len(public_url))\n",
    "    print(f\"\"\"\n",
    "╔══════════════════════════════════════════════════════════╗\n",
    "║  🚀  Doc Agent is LIVE!                                  ║\n",
    "║                                                          ║\n",
    "║  Open this URL in your browser:                          ║\n",
    "║  {public_url}{pad}║\n",
    "║                                                          ║\n",
    "║  Login credentials:  demo / demo                         ║\n",
    "║                                                          ║\n",
    "║  Keep this notebook tab open — closing it stops the app  ║\n",
    "╚══════════════════════════════════════════════════════════╝\n",
    "\"\"\")\n",
    "else:\n",
    "    print(\"\\n❌ Cloudflare tunnel failed. Trying localtunnel fallback...\")\n",
    "    import urllib.request\n",
    "    ip = urllib.request.urlopen(\"https://ipv4.icanhazip.com\").read().decode().strip()\n",
    "    print(f\"When asked for a password, enter: {ip}\")\n",
    "    !npm install -g localtunnel --silent 2>/dev/null\n",
    "    !lt --port 8501"
   ]
  },

